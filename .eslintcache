ath":"94","messages":"95","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"96","usedDeprecatedRules":"59"},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"59"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"59"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"59"},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"59"},{"filePath":"105","messages":"106","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"59"},{"filePath":"107","messages":"108","errorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"109","messages":"110","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"111","usedDeprecatedRules":"59"},{"filePath":"112","messages":"113","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"114","messages":"115","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"116","messages":"117","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\EstudaMais\\estuda_mais\\src\\serviceWorkerRegistration.js",[],["118","119"],"D:\\EstudaMais\\estuda_mais\\src\\firebase_config\\firebase.js",[],"D:\\EstudaMais\\estuda_mais\\src\\App.js",[],"D:\\EstudaMais\\estuda_mais\\src\\index.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\SignUp\\SignUp.js",["120"],"import React, { useState } from \"react\";\r\nimport \"./SignUp.css\";\r\nimport { useAuth } from \"../../contexts/AuthContext\";\r\nimport { useHistory, Link } from \"react-router-dom\";\r\nimport {\r\n  Flex,\r\n  Box,\r\n  Heading,\r\n  FormControl,\r\n  FormLabel,\r\n  Input,\r\n  Button,\r\n  Text,\r\n  Alert,\r\n  AlertIcon,\r\n  useToast,\r\n  useColorMode,\r\n} from \"@chakra-ui/react\";\r\nimport { ArrowForwardIcon } from \"@chakra-ui/icons\";\r\nimport logo from \"../../images/logo.svg\";\r\nimport lightLogo from \"../../images/light-logo.svg\";\r\n\r\nfunction SignUp() {\r\n  const [email, setEmail] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const [username, setUsername] = useState(\"\");\r\n  const [confirmPassword, setConfirmPassword] = useState(\"\");\r\n  const { signup, currentUser } = useAuth();\r\n  const [error, setError] = useState(\"\");\r\n  const [loading, setLoading] = useState(false);\r\n  const history = useHistory();\r\n  const toast = useToast();\r\n  const { colorMode } = useColorMode();\r\n\r\n  function handlePasswordChange(e) {\r\n    setPassword(e.target.value);\r\n  }\r\n\r\n  function handleEmailChange(e) {\r\n    setEmail(e.target.value);\r\n  }\r\n\r\n  function handleConfirmPasswordChange(e) {\r\n    setConfirmPassword(e.target.value);\r\n  }\r\n\r\n  function handleUsernameChange(e) {\r\n    setUsername(e.target.value);\r\n  }\r\n\r\n\r\n  async function handleSubmit(e) {\r\n    e.preventDefault();\r\n\r\n    if (password !== confirmPassword) {\r\n      return setError(\"As palavras passes não correspondem\");\r\n    }\r\n\r\n    try {\r\n      setError(\"\");\r\n      setLoading(true);\r\n      await signup(email, password, username);\r\n      history.push(\"/\");\r\n      toast({\r\n        title: \"Account Created.\",\r\n        description: `Account created succecefuly.`,\r\n        status: \"success\",\r\n        duration: 7000,\r\n        isClosable: true,\r\n      });\r\n    } catch (error) {\r\n      setError(error.message);\r\n    }\r\n\r\n    setLoading(false);\r\n  }\r\n\r\n  return (\r\n    <>\r\n      <Flex\r\n        wrap=\"wrap\"\r\n        width=\"full\"\r\n        mt={20}\r\n        align=\"center\"\r\n        justifyContent=\"center\"\r\n      >\r\n        <Box p={4} width={500}>\r\n          <Box textAlign=\"center\" alignContent=\"center\">\r\n            <img\r\n              src={colorMode === \"dark\" ? lightLogo : logo}\r\n              style={{ margin: \"auto\" }}\r\n              alt=\"Logo Estuda+\"\r\n            />\r\n          </Box>\r\n          <Box mt={7} p={8} borderWidth={1} borderRadius={8} boxShadow=\"lg\">\r\n            <Heading textAlign=\"center\">Register</Heading>\r\n            {error && (\r\n              <Alert borderRadius={10} mt={4} status=\"error\">\r\n                <AlertIcon /> {error}\r\n              </Alert>\r\n            )}\r\n            <form onSubmit={handleSubmit}>\r\n              <FormControl mt={6}>\r\n                <FormLabel>Username</FormLabel>\r\n                <Input\r\n                  value={username}\r\n                  onChange={handleUsernameChange}\r\n                  type=\"name\"\r\n                  required\r\n                  placeholder=\"ex: AlbertoJosias123\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Email</FormLabel>\r\n                <Input\r\n                  value={email}\r\n                  onChange={handleEmailChange}\r\n                  type=\"email\"\r\n                  required\r\n                  placeholder=\"name@example.com\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Password</FormLabel>\r\n                <Input\r\n                  value={password}\r\n                  onChange={handlePasswordChange}\r\n                  type=\"password\"\r\n                  required\r\n                  placeholder=\"Password...\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Confirm Password</FormLabel>\r\n                <Input\r\n                  value={confirmPassword}\r\n                  onChange={handleConfirmPasswordChange}\r\n                  type=\"password\"\r\n                  required\r\n                  placeholder=\"Confirm your password...\"\r\n                />\r\n              </FormControl>\r\n\r\n              <Button\r\n                width=\"full\"\r\n                mt={6}\r\n                disabled={loading}\r\n                rightIcon={<ArrowForwardIcon />}\r\n                type=\"submit\"\r\n                colorScheme=\"teal\"\r\n              >\r\n                Register\r\n              </Button>\r\n            </form>\r\n            <Box textAlign=\"center\" mt={4}>\r\n              <Text>\r\n                Already have an account?{\" \"}\r\n                <Link style={{ color: \"teal\" }} to=\"/login\">\r\n                  Login\r\n                </Link>\r\n              </Text>\r\n              <Box mt={4}>\r\n                <Link style={{ color: \"teal\" }} to=\"/\">\r\n                  Back to Home.\r\n                </Link>\r\n              </Box>\r\n            </Box>\r\n          </Box>\r\n        </Box>\r\n      </Flex>\r\n    </>\r\n  );\r\n}\r\n\r\nexport default SignUp;\r\n","D:\\EstudaMais\\estuda_mais\\src\\contexts\\AuthContext.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Dashboard\\Dashboard.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Login\\Login.js",[],"D:\\EstudaMais\\estuda_mais\\src\\ThemeToggler.js",["121"],"import React from \"react\";\r\nimport { useColorMode, Box, Button, IconButton } from \"@chakra-ui/react\";\r\nimport { MoonIcon, SunIcon } from \"@chakra-ui/icons\";\r\n\r\nexport default function ThemeToggler() {\r\n  const { colorMode, toggleColorMode } = useColorMode();\r\n  return (\r\n    <Box textAlign=\"right\" py={4} mr={4}>\r\n      <IconButton\r\n        aria-label=\"Search database\"\r\n        onClick={toggleColorMode}\r\n        icon={colorMode === \"light\" ? <MoonIcon /> : <SunIcon />}\r\n      />\r\n    </Box>\r\n  );\r\n}\r\n",["122","123"],"D:\\EstudaMais\\estuda_mais\\src\\routes\\PrivateRoute.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Home\\Home.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\Navbar.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\NavbarItems.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Card\\Card.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Profile\\Profile.js",["124"],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\Subject.js",["125","126","127"],"import React, { useEffect, useState } from \"react\";\r\nimport ResourceCard from \"../ResourceCard/ResourceCard\";\r\nimport {\r\n  Flex,\r\n  Text,\r\n  Box,\r\n  Alert,\r\n  AlertIcon,\r\n  Input,\r\n  Skeleton,\r\n  IconButton,\r\n  Button,\r\n} from \"@chakra-ui/react\";\r\nimport { SearchIcon } from \"@chakra-ui/icons\";\r\nimport Navbar from \"../Navbar/Navbar\";\r\nimport \"firebase/firestore\";\r\nimport usePerformFirebaseQuery from \"../../helpers/resources/queries\";\r\n\r\nfunction Subject({ year, subject }) {\r\n  const [search, setSearch] = useState(\"\");\r\n  const { resource, loading, latestQuery } = usePerformFirebaseQuery(year, subject);\r\n\r\n  return (\r\n    <>\r\n      <Navbar />\r\n      <Skeleton isLoaded={!loading}>\r\n        <Text mt={10} fontSize={32} textAlign=\"center\">\r\n          {subject} - {year} ano\r\n        </Text>\r\n\r\n        <Flex alignItems=\"center\" justifyContent=\"center\" mt={12}>\r\n          <Box maxW={350}>\r\n            <Input\r\n              borderRightRadius={0}\r\n              placeholder=\"Search Resource name\"\r\n              onChange={(e) => {\r\n                setSearch(e.target.value);\r\n              }}\r\n            />\r\n          </Box>\r\n          <IconButton borderLeftRadius={0} icon={<SearchIcon />} />\r\n        </Flex>\r\n        <Flex alignItems=\"center\" justifyContent=\"space-around\" wrap=\"wrap\">\r\n          {resource.length === 0 ? (\r\n            <Box mt={10}>\r\n              <Alert\r\n                status=\"warning\"\r\n                textAlign=\"center\"\r\n                borderRadius={5}\r\n                size=\"lg\"\r\n              >\r\n                <AlertIcon />\r\n                Ainda sem recursos aqui.\r\n              </Alert>\r\n            </Box>\r\n          ) : (\r\n            resource\r\n              .filter((val) => {\r\n                if (search === \"\") return val;\r\n                else if (\r\n                  val.name.toLowerCase().includes(search.toLocaleLowerCase())\r\n                ) {\r\n                  return val;\r\n                }\r\n              })\r\n              .map((item, index) => {\r\n                return (\r\n                  <Box key={index}>\r\n                    <ResourceCard\r\n                      author={item.author}\r\n                      resourceName={item.name}\r\n                      resourceURL={item.url}\r\n                    />\r\n                  </Box>\r\n                );\r\n              })\r\n          )}\r\n        </Flex>\r\n        {resource.length === 4 ? (\r\n          <Box textAlign=\"center\" mt={4}>\r\n            <Button>Load More</Button>\r\n          </Box>\r\n        ) : null}\r\n      </Skeleton>\r\n    </>\r\n  );\r\n}\r\n\r\nexport default Subject;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\ResourceCard\\ResourceCard.js",["128"],"import React from \"react\";\r\nimport { Box, Button, Divider, Text } from \"@chakra-ui/react\";\r\nimport { DownloadIcon } from '@chakra-ui/icons'\r\n\r\nfunction ResourceCard({ resourceName, author, resourceURL }) {\r\n  return (\r\n    <Box\r\n      borderRadius={7}\r\n      mt={16}\r\n      w={300}\r\n      borderWidth={1}\r\n      boxShadow=\"2xl\"\r\n      padding={5}\r\n      mb={10}\r\n      mr={12}\r\n      ml={12}\r\n    >\r\n      <Text color=\"blue.500\" fontSize={26} fontWeight=\"bold\" textAlign=\"center\">\r\n        {author}\r\n      </Text>\r\n      <Text mt={7} fontSize={20} textAlign=\"center\">\r\n        {resourceName}\r\n      </Text>\r\n      <Box textAlign=\"center\" mt={7}>\r\n        <Button\r\n          as=\"a\"\r\n          download\r\n          target=\"blank\"\r\n          rel=\"noopener noreferrer\"\r\n          href={resourceURL}\r\n          colorScheme=\"blue\"\r\n          fontSize=\"20px\"\r\n          variant=\"ghost\"\r\n          rightIcon={<DownloadIcon fontSize=\"20px\"/>}\r\n        >\r\n          Download\r\n        </Button>\r\n      </Box>\r\n    </Box>\r\n  );\r\n}\r\n\r\nexport default ResourceCard;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Mat11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Bg11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Fq11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Pt11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\About\\About.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\SearchProfile\\SearchProfile.js",["129","130","131","132","133"],"D:\\EstudaMais\\estuda_mais\\src\\helpers\\resources\\queries.js",["134","135"],"import React, { useState, useEffect } from \"react\";\r\nimport \"firebase/firestore\";\r\nimport firebase from \"firebase/app\";\r\nconst db = firebase.firestore();\r\n\r\nfunction usePerformFirebaseQuery(year, subject, limit) {\r\n  const [loading, setLoading] = useState(true);\r\n  const [resource, setResource] = useState([]);\r\n\r\n  useEffect(() => {\r\n    const performQuery = async () => {\r\n      setLoading(true);\r\n\r\n      const query = await db\r\n        .collection(\"resource\")\r\n        .where(\"year\", \"==\", year)\r\n        .where(\"subject\", \"==\", subject)\r\n        .get();\r\n      for (const year of query.docs) {\r\n        const data = year.data();\r\n        setResource((prevState) => prevState.concat(data));\r\n      }\r\n    };\r\n    performQuery();\r\n    setLoading(false);\r\n  }, []);\r\n\r\n  return { resource, loading };\r\n}\r\n\r\n\r\n\r\nexport default usePerformFirebaseQuery\r\n","D:\\EstudaMais\\estuda_mais\\src\\helpers\\profiles\\query.js",["136"],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Fil11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Ef.js",[],{"ruleId":"137","replacedBy":"138"},{"ruleId":"139","replacedBy":"140"},{"ruleId":"141","severity":1,"message":"142","line":28,"column":19,"nodeType":"143","messageId":"144","endLine":28,"endColumn":30},{"ruleId":"141","severity":1,"message":"145","line":2,"column":29,"nodeType":"143","messageId":"144","endLine":2,"endColumn":35},{"ruleId":"137","replacedBy":"146"},{"ruleId":"139","replacedBy":"147"},{"ruleId":"141","severity":1,"message":"148","line":39,"column":10,"nodeType":"143","messageId":"144","endLine":39,"endColumn":30},{"ruleId":"141","severity":1,"message":"149","line":1,"column":17,"nodeType":"143","messageId":"144","endLine":1,"endColumn":26},{"ruleId":"141","severity":1,"message":"150","line":21,"column":30,"nodeType":"143","messageId":"144","endLine":21,"endColumn":41},{"ruleId":"151","severity":1,"message":"152","line":58,"column":29,"nodeType":"153","messageId":"154","endLine":58,"endColumn":31},{"ruleId":"141","severity":1,"message":"155","line":2,"column":23,"nodeType":"143","messageId":"144","endLine":2,"endColumn":30},{"ruleId":"141","severity":1,"message":"156","line":20,"column":3,"nodeType":"143","messageId":"144","endLine":20,"endColumn":11},{"ruleId":"141","severity":1,"message":"157","line":32,"column":10,"nodeType":"143","messageId":"144","endLine":32,"endColumn":25},{"ruleId":"141","severity":1,"message":"158","line":32,"column":27,"nodeType":"143","messageId":"144","endLine":32,"endColumn":45},{"ruleId":"151","severity":1,"message":"152","line":92,"column":37,"nodeType":"153","messageId":"154","endLine":92,"endColumn":39},{"ruleId":"159","severity":1,"message":"160","line":103,"column":25,