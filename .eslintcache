rorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"D:\\EstudaMais\\estuda_mais\\src\\serviceWorkerRegistration.js",[],["67","68"],"D:\\EstudaMais\\estuda_mais\\src\\firebase_config\\firebase.js",[],"D:\\EstudaMais\\estuda_mais\\src\\App.js",[],"D:\\EstudaMais\\estuda_mais\\src\\index.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\SignUp\\SignUp.js",["69","70"],"import React, { useState } from \"react\";\r\nimport \"./SignUp.css\";\r\nimport { useAuth } from \"../../contexts/AuthContext\";\r\nimport { useHistory, Link } from \"react-router-dom\";\r\nimport {\r\n  Flex,\r\n  Box,\r\n  Heading,\r\n  FormControl,\r\n  FormLabel,\r\n  Input,\r\n  Button,\r\n  Text,\r\n  Alert,\r\n  AlertIcon,\r\n  useToast,\r\n  useColorMode,\r\n} from \"@chakra-ui/react\";\r\nimport { ArrowForwardIcon } from \"@chakra-ui/icons\";\r\nimport logo from \"../../images/logo.svg\";\r\nimport lightLogo from \"../../images/light-logo.svg\";\r\nimport Navbar from \"../Navbar/Navbar\";\r\n\r\nfunction SignUp() {\r\n  const [email, setEmail] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const [username, setUsername] = useState(\"\");\r\n  const [confirmPassword, setConfirmPassword] = useState(\"\");\r\n  const { signup, currentUser } = useAuth();\r\n  const [error, setError] = useState(\"\");\r\n  const [loading, setLoading] = useState(false);\r\n  const history = useHistory();\r\n  const toast = useToast();\r\n  const { colorMode } = useColorMode();\r\n\r\n  function handlePasswordChange(e) {\r\n    setPassword(e.target.value);\r\n  }\r\n\r\n  function handleEmailChange(e) {\r\n    setEmail(e.target.value);\r\n  }\r\n\r\n  function handleConfirmPasswordChange(e) {\r\n    setConfirmPassword(e.target.value);\r\n  }\r\n\r\n  function handleUsernameChange(e) {\r\n    setUsername(e.target.value);\r\n  }\r\n\r\n  async function handleSubmit(e) {\r\n    e.preventDefault();\r\n\r\n    if (password !== confirmPassword) {\r\n      return setError(\"As palavras passes não correspondem\");\r\n    }\r\n\r\n    try {\r\n      setError(\"\");\r\n      setLoading(true);\r\n      await signup(email, password, username);\r\n      history.push(\"/\");\r\n      toast({\r\n        title: \"Conta criada\",\r\n        description: `Conta criada com sucesso.`,\r\n        status: \"success\",\r\n        duration: 7000,\r\n        isClosable: true,\r\n      });\r\n    } catch (error) {\r\n      setError(error.message);\r\n    }\r\n\r\n    setLoading(false);\r\n  }\r\n\r\n  return (\r\n    <>\r\n      <Flex\r\n        wrap=\"wrap\"\r\n        width=\"full\"\r\n        mt={20}\r\n        align=\"center\"\r\n        justifyContent=\"center\"\r\n      >\r\n        <Box p={4} width={500}>\r\n          <Box textAlign=\"center\" alignContent=\"center\">\r\n            <img\r\n              src={colorMode === \"dark\" ? lightLogo : logo}\r\n              style={{ margin: \"auto\" }}\r\n              alt=\"Logo Estuda+\"\r\n            />\r\n          </Box>\r\n          <Box mt={7} p={8} borderWidth={1} borderRadius={8} boxShadow=\"lg\">\r\n            <Heading textAlign=\"center\">Registar</Heading>\r\n            {error && (\r\n              <Alert borderRadius={10} mt={4} status=\"error\">\r\n                <AlertIcon /> {error}\r\n              </Alert>\r\n            )}\r\n            <form onSubmit={handleSubmit}>\r\n              <FormControl mt={6}>\r\n                <FormLabel>Username</FormLabel>\r\n                <Input\r\n                  value={username}\r\n                  onChange={handleUsernameChange}\r\n                  type=\"name\"\r\n                  required\r\n                  placeholder=\"ex: AlbertoJosias123\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Email</FormLabel>\r\n                <Input\r\n                  value={email}\r\n                  onChange={handleEmailChange}\r\n                  type=\"email\"\r\n                  required\r\n                  placeholder=\"nome@exemplo.com\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Palavra-Passe</FormLabel>\r\n                <Input\r\n                  value={password}\r\n                  onChange={handlePasswordChange}\r\n                  type=\"password\"\r\n                  required\r\n                  placeholder=\"Palavra-Passe...\"\r\n                />\r\n              </FormControl>\r\n\r\n              <FormControl mt={6}>\r\n                <FormLabel>Confirmar Palavra-Passe</FormLabel>\r\n                <Input\r\n                  value={confirmPassword}\r\n                  onChange={handleConfirmPasswordChange}\r\n                  type=\"password\"\r\n                  required\r\n                  placeholder=\"Confirma a tua Palavra-Passe\"\r\n                />\r\n              </FormControl>\r\n\r\n              <Button\r\n                width=\"full\"\r\n                mt={6}\r\n                disabled={loading}\r\n                rightIcon={<ArrowForwardIcon />}\r\n                type=\"submit\"\r\n                colorScheme=\"teal\"\r\n              >\r\n                Registar\r\n              </Button>\r\n            </form>\r\n            <Box textAlign=\"center\" mt={4}>\r\n              <Text>\r\n                Já tens uma conta?{\" \"}\r\n                <Link style={{ color: \"teal\" }} to=\"/login\">\r\n                  Entrar\r\n                </Link>\r\n              </Text>\r\n              <Box mt={4}>\r\n                <Link style={{ color: \"teal\" }} to=\"/\">\r\n                  Voltar ao Início\r\n                </Link>\r\n              </Box>\r\n            </Box>\r\n          </Box>\r\n        </Box>\r\n      </Flex>\r\n    </>\r\n  );\r\n}\r\n\r\nexport default SignUp;\r\n","D:\\EstudaMais\\estuda_mais\\src\\contexts\\AuthContext.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Dashboard\\Dashboard.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Login\\Login.js",["71"],"import React, { useState } from \"react\";\r\nimport { useAuth } from \"../../contexts/AuthContext\";\r\nimport { Link, useHistory } from \"react-router-dom\";\r\nimport {\r\n  Flex,\r\n  Box,\r\n  Heading,\r\n  FormControl,\r\n  FormLabel,\r\n  Input,\r\n  Button,\r\n  Alert,\r\n  AlertIcon,\r\n  Text,\r\n  useToast,\r\n  useColorMode,\r\n} from \"@chakra-ui/react\";\r\nimport { ArrowForwardIcon } from \"@chakra-ui/icons\";\r\nimport logo from \"../../images/logo.svg\";\r\nimport lightLogo from \"../../images/light-logo.svg\";\r\n\r\nfunction Login() {\r\n  const [email, setEmail] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const { login, currentUser, logout } = useAuth();\r\n  const [error, setError] = useState(\"\");\r\n  const [loading, setLoading] = useState(false);\r\n  const history = useHistory();\r\n  const { colorMode } = useColorMode();\r\n\r\n  const toast = useToast();\r\n\r\n  function handlePasswordChange(e) {\r\n    setPassword(e.target.value);\r\n  }\r\n\r\n  function handleEmailChange(e) {\r\n    setEmail(e.target.value);\r\n  }\r\n\r\n  async function handleSubmit(e) {\r\n    e.preventDefault();\r\n\r\n    try {\r\n      setError(\"\");\r\n      setLoading(true);\r\n      await login(email, password);\r\n      history.push(\"/\");\r\n      toast({\r\n        title: \"Login feito com sucesso\",\r\n        description: `Entraste com a tua conta associada ao email ${currentUser.email}.`,\r\n        isClosable: true,\r\n        status: \"success\",\r\n        duration: 5000,\r\n      });\r\n    } catch (error) {\r\n      setError(\r\n        \"Erro ao entrar. A palavra passe ou o email podem estar incorretos.\"\r\n      );\r\n    }\r\n\r\n    setLoading(false);\r\n  }\r\n  return (\r\n    <Flex width=\"full\" mt={20} align=\"center\" justifyContent=\"center\">\r\n      <Box p={4} width={500}>\r\n        <Box textAlign=\"center\" alignContent=\"center\">\r\n          <img\r\n            src={colorMode === \"dark\" ? lightLogo : logo}\r\n            style={{ margin: \"auto\" }}\r\n            alt=\"Logo Estuda+\"\r\n          />\r\n        </Box>\r\n        <Box mt={7} p={8} borderWidth={1} borderRadius={8} boxShadow=\"lg\">\r\n          <Heading textAlign=\"center\">Entrar</Heading>\r\n          {error && (\r\n            <Alert borderRadius={10} mt={4} status=\"error\">\r\n              <AlertIcon />\r\n              {error}\r\n            </Alert>\r\n          )}\r\n          <form onSubmit={handleSubmit}>\r\n            <Box mt={2} textAlign=\"center\">\r\n              <Link style={{ color: \"teal\", fontSize: 14 }} to=\"/\">\r\n                Voltar ao Início\r\n              </Link>\r\n            </Box>\r\n            <FormControl mt={4}>\r\n              <FormLabel>Email</FormLabel>\r\n              <Input\r\n                value={email}\r\n                onChange={handleEmailChange}\r\n                type=\"email\"\r\n                required\r\n                placeholder=\"nome@exemplo.com\"\r\n              />\r\n            </FormControl>\r\n\r\n            <FormControl mt={6}>\r\n              <FormLabel>Palavra-Passe</FormLabel>\r\n              <Input\r\n                value={password}\r\n                onChange={handlePasswordChange}\r\n                type=\"password\"\r\n                required\r\n                placeholder=\"Palavra-Passe...\"\r\n              />\r\n            </FormControl>\r\n\r\n            <Button\r\n              width=\"full\"\r\n              mt={4}\r\n              disabled={loading}\r\n              colorScheme=\"teal\"\r\n              rightIcon={<ArrowForwardIcon />}\r\n              type=\"submit\"\r\n            >\r\n              Entrar\r\n            </Button>\r\n          </form>\r\n          <Box textAlign=\"center\" mt={5}>\r\n            <Text>\r\n              Ainda não tens um conta?{\" \"}\r\n              <Link style={{ color: \"teal\" }} to=\"/signup\">\r\n                Regista-te!\r\n              </Link>\r\n            </Text>\r\n          </Box>\r\n        </Box>\r\n      </Box>\r\n    </Flex>\r\n  );\r\n}\r\n\r\nexport default Login;\r\n","D:\\EstudaMais\\estuda_mais\\src\\ThemeToggler.js",["72"],"import React from \"react\";\r\nimport { useColorMode, Box, Button, IconButton } from \"@chakra-ui/react\";\r\nimport { MoonIcon, SunIcon } from \"@chakra-ui/icons\";\r\n\r\nexport default function ThemeToggler() {\r\n  const { colorMode, toggleColorMode } = useColorMode();\r\n  return (\r\n    <Box textAlign=\"right\" py={4} mr={4}>\r\n      <IconButton\r\n        aria-label=\"Search database\"\r\n        onClick={toggleColorMode}\r\n        icon={colorMode === \"light\" ? <MoonIcon /> : <SunIcon />}\r\n      />\r\n    </Box>\r\n  );\r\n}\r\n",["73","74"],"D:\\EstudaMais\\estuda_mais\\src\\routes\\PrivateRoute.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Home\\Home.js",["75","76","77"],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\Navbar.js",["78"],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\NavbarItems.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Card\\Card.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Profile\\Profile.js",["79"],{"ruleId":"80","replacedBy":"81"},{"ruleId":"82","replacedBy":"83"},{"ruleId":"84","severity":1,"message":"85","line":22,"column":8,"nodeType":"86","messageId":"87","endLine":22,"endColumn":14},{"ruleId":"84","severity":1,"message":"88","line":29,"column":19,"nodeType":"86","messageId":"87","endLine":29,"endColumn":30},{"ruleId":"84","severity":1,"message":"89","line":25,"column":31,"nodeType":"86","messageId":"87","endLine":25,"endColumn":37},{"ruleId":"84","severity":1,"message":"90","line":2,"column":29,"nodeType":"86","messageId":"87","endLine":2,"endColumn":35},{"ruleId":"80","replacedBy":"91"},{"ruleId":"82","replacedBy":"92"},{"ruleId":"84","severity":1,"message":"93","line":9,"