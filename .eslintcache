edRules":"48"},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},"D:\\EstudaMais\\estuda_mais\\src\\serviceWorkerRegistration.js",[],["95","96"],"D:\\EstudaMais\\estuda_mais\\src\\firebase_config\\firebase.js",[],"D:\\EstudaMais\\estuda_mais\\src\\App.js",[],"D:\\EstudaMais\\estuda_mais\\src\\index.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\SignUp\\SignUp.js",[],"D:\\EstudaMais\\estuda_mais\\src\\contexts\\AuthContext.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Dashboard\\Dashboard.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Login\\Login.js",[],"D:\\EstudaMais\\estuda_mais\\src\\ThemeToggler.js",["97"],"import React from \"react\";\r\nimport { useColorMode, Box, Button, IconButton } from \"@chakra-ui/react\";\r\nimport { MoonIcon, SunIcon } from \"@chakra-ui/icons\";\r\n\r\nexport default function ThemeToggler() {\r\n  const { colorMode, toggleColorMode } = useColorMode();\r\n  return (\r\n    <Box textAlign=\"right\" py={4} mr={4}>\r\n      <IconButton\r\n        aria-label=\"Search database\"\r\n        onClick={toggleColorMode}\r\n        icon={colorMode === \"light\" ? <MoonIcon /> : <SunIcon />}\r\n      />\r\n    </Box>\r\n  );\r\n}\r\n",["98","99"],"D:\\EstudaMais\\estuda_mais\\src\\routes\\PrivateRoute.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Home\\Home.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\Navbar.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\NavbarItems.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Card\\Card.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Profile\\Profile.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\Subject.js",["100","101","102"],"import React, { useEffect, useState } from \"react\";\r\nimport ResourceCard from \"../ResourceCard/ResourceCard\";\r\nimport {\r\n  Flex,\r\n  Text,\r\n  Box,\r\n  Alert,\r\n  AlertIcon,\r\n  Input,\r\n  Button,\r\n  IconButton,\r\n} from \"@chakra-ui/react\";\r\nimport { SearchIcon } from \"@chakra-ui/icons\";\r\nimport Navbar from \"../Navbar/Navbar\";\r\nimport \"firebase/firestore\";\r\nimport firebase from \"firebase/app\";\r\n\r\nfunction Subject({ year, subject }) {\r\n  const db = firebase.firestore();\r\n  const [resourceYear, setResourceYear] = useState([]);\r\n  const [search, setSearch] = useState(\"\");\r\n\r\n  useEffect(() => {\r\n    const preformQuery1 = async () => {\r\n      const query = await db\r\n        .collection(\"resource\")\r\n        .where(\"year\", \"==\", year)\r\n        .where(\"subject\", \"==\", subject)\r\n        .get();\r\n      for (const year of query.docs) {\r\n        const data = year.data();\r\n        setResourceYear((prevState) => prevState.concat(data));\r\n      }\r\n    };\r\n    preformQuery1();\r\n  }, []);\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      <Text mt={10} fontSize={32} textAlign=\"center\">\r\n        {subject} - {year} ano\r\n      </Text>\r\n\r\n      <Flex alignItems=\"center\" justifyContent=\"center\" mt={12}>\r\n        <Box maxW={350}>\r\n          <Input\r\n            borderRightRadius={0}\r\n            placeholder=\"Search Resource name\"\r\n            onChange={(e) => {\r\n              setSearch(e.target.value);\r\n            }}\r\n          />\r\n        </Box>\r\n        <IconButton borderLeftRadius={0} icon={<SearchIcon />} />\r\n      </Flex>\r\n      <Flex alignItems=\"center\" justifyContent=\"space-around\" wrap=\"wrap\">\r\n        {resourceYear.length === 0 ? (\r\n          <Box mt={10}>\r\n            <Alert\r\n              status=\"warning\"\r\n              textAlign=\"center\"\r\n              borderRadius={5}\r\n              size=\"lg\"\r\n            >\r\n              <AlertIcon />\r\n              Ainda sem recursos aqui.\r\n            </Alert>\r\n          </Box>\r\n        ) : (\r\n          resourceYear\r\n            .filter((val) => {\r\n              if (search === \"\") return val;\r\n              else if (\r\n                val.name.toLowerCase().includes(search.toLocaleLowerCase())\r\n              ) {\r\n                return val;\r\n              }\r\n            })\r\n            .map((item, index) => {\r\n              return (\r\n                <Box key={index}>\r\n                  <ResourceCard\r\n                    author={item.author}\r\n                    resourceName={item.name}\r\n                    resourceURL={item.url}\r\n                  />\r\n                </Box>\r\n              );\r\n            })\r\n        )}\r\n      </Flex>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Subject;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\ResourceCard\\ResourceCard.js",["103"],"import React from \"react\";\r\nimport { Box, Button, Divider, Text } from \"@chakra-ui/react\";\r\nimport { DownloadIcon } from '@chakra-ui/icons'\r\n\r\nfunction ResourceCard({ resourceName, author, resourceURL }) {\r\n  return (\r\n    <Box\r\n      borderRadius={7}\r\n      mt={16}\r\n      w={300}\r\n      borderWidth={1}\r\n      boxShadow=\"2xl\"\r\n      padding={7}\r\n      mb={10}\r\n      mr={12}\r\n      ml={12}\r\n    >\r\n      <Text color=\"blue.500\" fontSize={28} fontWeight=\"bold\" textAlign=\"center\">\r\n        {author}\r\n      </Text>\r\n      <Text mt={7} fontSize={22} textAlign=\"center\">\r\n        {resourceName}\r\n      </Text>\r\n      <Box textAlign=\"center\" mt={7}>\r\n        <Button\r\n          as=\"a\"\r\n          download\r\n          target=\"blank\"\r\n          rel=\"noopener noreferrer\"\r\n          href={resourceURL}\r\n          colorScheme=\"blue\"\r\n          rightIcon={<DownloadIcon fontSize=\"18px\"/>}\r\n        >\r\n          Download\r\n        </Button>\r\n      </Box>\r\n    </Box>\r\n  );\r\n}\r\n\r\nexport default ResourceCard;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Mat11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Bg11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Fq11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Pt11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\About\\About.js",[],{"ruleId":"104","replacedBy":"105"},{"ruleId":"106","replacedBy":"107"},{"ruleId":"108","severity":1,"message":"109","line":2,"column":29,"nodeType":"110","messageId":"111","endLine":2,"endColumn":35},{"ruleId":"104","replacedBy":"112"},{"ruleId":"106","replacedBy":"113"},{"ruleId":"108","severity":1,"message":"109","line":10,"column":3,"nodeType":"110","messageId":"111","endLine":10,"endColumn":9},{"ruleId":"114","severity":1,"message":"115","line":36,"column":6,"nodeType":"116","endLine":36,"endColumn":8,"suggestions":"117"},{"ruleId":"118","severity":1,"message":"119","line":72,"column":27,"nodeType":"120","messageId":"121","endLine":72,"endColumn":29},{"ruleId":"108","severity":1,"message":"122","line":2,"column":23,"nodeType":"110","messageId":"111","endLine":2,"endColumn":30},"no-native-reassign",["123"],"no-negated-in-lhs",["124"],"no-unused-vars","'Button' is defined but never used.","Identifier","unusedVar",["123"],["124"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'db', 'subject', and 'year'. Either include them or remove the dependency array.","ArrayExpression",["125"],"array-callback-return","Array.prototype.filter() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","'Divider' is defined but never used.","no-global-assign","no-unsafe-negation",{"desc":"126","fix":"127"},"Update the dependencies array to be: [db, subject, year]",{"range":"128","text":"129"},[976,978],"[db, subject, year]"]