arningCount":0,"usedDeprecatedRules":"48"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},"D:\\EstudaMais\\estuda_mais\\src\\serviceWorkerRegistration.js",[],["96","97"],"D:\\EstudaMais\\estuda_mais\\src\\firebase_config\\firebase.js",[],"D:\\EstudaMais\\estuda_mais\\src\\App.js",[],"D:\\EstudaMais\\estuda_mais\\src\\index.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\SignUp\\SignUp.js",[],"D:\\EstudaMais\\estuda_mais\\src\\contexts\\AuthContext.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Dashboard\\Dashboard.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Login\\Login.js",[],"D:\\EstudaMais\\estuda_mais\\src\\ThemeToggler.js",["98"],"import React from \"react\";\r\nimport { useColorMode, Box, Button, IconButton } from \"@chakra-ui/react\";\r\nimport { MoonIcon, SunIcon } from \"@chakra-ui/icons\";\r\n\r\nexport default function ThemeToggler() {\r\n  const { colorMode, toggleColorMode } = useColorMode();\r\n  return (\r\n    <Box textAlign=\"right\" py={4} mr={4}>\r\n      <IconButton\r\n        aria-label=\"Search database\"\r\n        onClick={toggleColorMode}\r\n        icon={colorMode === \"light\" ? <MoonIcon /> : <SunIcon />}\r\n      />\r\n    </Box>\r\n  );\r\n}\r\n",["99","100"],"D:\\EstudaMais\\estuda_mais\\src\\routes\\PrivateRoute.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Home\\Home.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\Navbar.js",["101"],"import React from \"react\";\r\nimport {\r\n  Flex,\r\n  Box,\r\n  Link,\r\n  IconButton,\r\n  useDisclosure,\r\n  Drawer,\r\n  DrawerBody,\r\n  DrawerOverlay,\r\n  DrawerHeader,\r\n  DrawerContent,\r\n  Divider,\r\n  Img,\r\n  useColorMode,\r\n  Menu,\r\n  MenuButton,\r\n  MenuItem,\r\n  MenuList,\r\n  Button,\r\n} from \"@chakra-ui/react\";\r\nimport logo from \"../../images/light-logo.svg\";\r\nimport drawerImage from \"../../images/drawer-image.svg\";\r\nimport { Link as ChakraLink } from \"react-router-dom\";\r\nimport {\r\n  HamburgerIcon,\r\n  CloseIcon,\r\n  SunIcon,\r\n  MoonIcon,\r\n  ChevronDownIcon,\r\n  LockIcon,\r\n} from \"@chakra-ui/icons\";\r\nimport \"./Navbar.css\";\r\nimport { MiddleNavbarItems, RigthNavbarItems } from \"./NavbarItems\";\r\nimport { useAuth } from \"../../contexts/AuthContext\";\r\n\r\nfunction Navbar(props) {\r\n  const { isOpen, onOpen, onClose } = useDisclosure();\r\n  const { colorMode, toggleColorMode } = useColorMode();\r\n  const { currentUser, logout } = useAuth();\r\n\r\n  async function onClickLogout() {\r\n    try {\r\n      await logout();\r\n    } catch {\r\n      console.log(\"Failed to logout.\");\r\n    }\r\n  }\r\n\r\n  return (\r\n    <Box boxShadow=\"2xl\">\r\n      <Flex\r\n        boxShadow=\"lg\"\r\n        as=\"nav\"\r\n        align=\"center\"\r\n        justify=\"space-between\"\r\n        wrap=\"wrap\"\r\n        className=\"navbar\"\r\n        padding=\"1.5rem\"\r\n        bg=\"gray.800\"\r\n        color=\"white\"\r\n        {...props}\r\n      >\r\n        <Flex>\r\n          <img src={logo} alt=\"Logo Navbar\" width={200} height={200} />\r\n          <IconButton\r\n            mt={5}\r\n            onClick={toggleColorMode}\r\n            size=\"sm\"\r\n            variant=\"ghost\"\r\n            _hover={{ backgroundColor: \"transparent\" }}\r\n            colorScheme=\"blue\"\r\n            icon={colorMode === \"dark\" ? <SunIcon /> : <MoonIcon />}\r\n          />\r\n        </Flex>\r\n        <Flex className={isOpen ? \"nav-menu active\" : \"nav-menu\"}>\r\n          {MiddleNavbarItems.map((item, index) => {\r\n            return (\r\n              <Flex key={index}>\r\n                <Menu>\r\n                  <MenuButton\r\n                    className={item.cName}\r\n                    to={item.url}\r\n                    fontSize={22}\r\n                  >\r\n                    {item.title} <ChevronDownIcon />\r\n                  </MenuButton>\r\n                  <MenuList\r\n                    color={colorMode === \"dark\" ? \"whitesmoke\" : \"black\"}\r\n                  >\r\n                    <ChakraLink to=\"/mat11\">\r\n                      <MenuItem>{item.as1}</MenuItem> {/*  Mat  */}\r\n                    </ChakraLink>\r\n\r\n                    <ChakraLink to=\"/fq11\">\r\n                      <MenuItem>{item.as2}</MenuItem> {/*  FQ  */}\r\n                    </ChakraLink>\r\n\r\n                    <ChakraLink to=\"/bg11\">\r\n                      <MenuItem>{item.as3}</MenuItem> {/*  BG  */}\r\n                    </ChakraLink>\r\n\r\n                    <ChakraLink to=\"/pt11\">\r\n                      <MenuItem>{item.as4}</MenuItem> {/*  PT  */}\r\n                    </ChakraLink>\r\n                  </MenuList>\r\n                </Menu>\r\n              </Flex>\r\n            );\r\n          })}\r\n        </Flex>\r\n\r\n        <Flex className=\"nav-menu\">\r\n          <Box>\r\n            <Link as={ChakraLink} to=\"/\" color=\"gray.300\" fontSize={22}>\r\n              Home\r\n            </Link>\r\n          </Box>\r\n\r\n          <Box ml={7}>\r\n            <Link as={ChakraLink} to=\"/about\" color=\"gray.300\" fontSize={22}>\r\n              About\r\n            </Link>\r\n          </Box>\r\n\r\n          <Box ml={7}>\r\n            <Link as={ChakraLink} to=\"/profile\" color=\"gray.300\" fontSize={22}>\r\n              Profile\r\n            </Link>\r\n          </Box>\r\n          {currentUser ? (\r\n            <Box textAlign=\"center\" mt={0.2} ml={7}>\r\n              <Button\r\n                onClick={onClickLogout}\r\n                variant=\"outline\"\r\n                colorScheme=\"black\"\r\n                size=\"sm\"\r\n              >\r\n                Logout\r\n              </Button>\r\n            </Box>\r\n          ) : null}\r\n        </Flex>\r\n\r\n        <IconButton\r\n          variant=\"ghost\"\r\n          onClick={onOpen}\r\n          colorScheme=\"transparent\"\r\n          color=\"white\"\r\n          className=\"menu-navbar\"\r\n        >\r\n          <HamburgerIcon fontSize={24} />\r\n        </IconButton>\r\n        <Drawer placement=\"left\" size=\"full\" onClose={onClose} isOpen={isOpen}>\r\n          <DrawerOverlay>\r\n            <DrawerContent>\r\n              <DrawerHeader borderBottomWidth=\"1px\">\r\n                <Flex justifyContent=\"flex-end\">\r\n                  <IconButton\r\n                    variant=\"ghost\"\r\n                    onClick={onClose}\r\n                    icon={<CloseIcon />}\r\n                  />\r\n                </Flex>\r\n              </DrawerHeader>\r\n              <DrawerBody>\r\n                {RigthNavbarItems.map((item, index) => {\r\n                  return (\r\n                    <Flex\r\n                      key={index}\r\n                      alignItems=\"center\"\r\n                      justifyContent=\"center\"\r\n                    >\r\n                      <Link\r\n                        as={ChakraLink}\r\n                        className={item.cName}\r\n                        to={item.url}\r\n                        fontSize={32}\r\n                      >\r\n                        {item.title}\r\n                      </Link>\r\n                    </Flex>\r\n                  );\r\n                })}\r\n                <Box textAlign=\"center\">\r\n                  <Button\r\n                    onClick={onClickLogout}\r\n                    variant=\"outline\"\r\n                    colorScheme=\"black\"\r\n                    size=\"sm\"\r\n                  >\r\n                    Logout\r\n                  </Button>\r\n                </Box>\r\n                <Divider mt={2} />\r\n                <Flex mt={4} alignItems=\"center\" justifyContent=\"center\">\r\n                  {MiddleNavbarItems.map((item, index) => {\r\n                    return (\r\n                      <Flex key={index}>\r\n                        <Menu>\r\n                          <MenuButton\r\n                            className={item.cName}\r\n                            to={item.url}\r\n                            fontSize={32}\r\n                          >\r\n                            {item.title} <ChevronDownIcon />\r\n                          </MenuButton>\r\n                          <MenuList>\r\n                            <ChakraLink to=\"/mat11\">\r\n                              <MenuItem>{item.as1}</MenuItem>\r\n                            </ChakraLink>\r\n\r\n                            <ChakraLink to=\"/fq11\">\r\n                              <MenuItem>{item.as2}</MenuItem>\r\n                            </ChakraLink>\r\n\r\n                            <ChakraLink to=\"/bg11\">\r\n                              <MenuItem>{item.as3}</MenuItem>\r\n                            </ChakraLink>\r\n\r\n                            <ChakraLink to=\"/pt11\">\r\n                              <MenuItem>{item.as4}</MenuItem>\r\n                            </ChakraLink>\r\n                          </MenuList>\r\n                        </Menu>\r\n                      </Flex>\r\n                    );\r\n                  })}\r\n                </Flex>\r\n                <Img mt={20} src={drawerImage} alt=\"Studying\" />\r\n              </DrawerBody>\r\n            </DrawerContent>\r\n          </DrawerOverlay>\r\n        </Drawer>\r\n      </Flex>\r\n    </Box>\r\n  );\r\n}\r\n\r\nexport default Navbar;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\Navbar\\NavbarItems.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Card\\Card.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Profile\\Profile.js",["102"],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\Subject.js",["103","104","105"],"import React, { useEffect, useState } from \"react\";\r\nimport ResourceCard from \"../ResourceCard/ResourceCard\";\r\nimport {\r\n  Flex,\r\n  Text,\r\n  Box,\r\n  Alert,\r\n  AlertIcon,\r\n  Input,\r\n  Button,\r\n  IconButton,\r\n} from \"@chakra-ui/react\";\r\nimport { SearchIcon } from \"@chakra-ui/icons\";\r\nimport Navbar from \"../Navbar/Navbar\";\r\nimport \"firebase/firestore\";\r\nimport firebase from \"firebase/app\";\r\n\r\nfunction Subject({ year, subject }) {\r\n  const db = firebase.firestore();\r\n  const [resourceYear, setResourceYear] = useState([]);\r\n  const [search, setSearch] = useState(\"\");\r\n\r\n  useEffect(() => {\r\n    const preformQuery1 = async () => {\r\n      const query = await db\r\n        .collection(\"resource\")\r\n        .where(\"year\", \"==\", year)\r\n        .where(\"subject\", \"==\", subject)\r\n        .get();\r\n      for (const year of query.docs) {\r\n        const data = year.data();\r\n        setResourceYear((prevState) => prevState.concat(data));\r\n      }\r\n    };\r\n    preformQuery1();\r\n  }, []);\r\n\r\n  return (\r\n    <div>\r\n      <Navbar />\r\n      <Text mt={10} fontSize={32} textAlign=\"center\">\r\n        {subject} - {year} ano\r\n      </Text>\r\n\r\n      <Flex alignItems=\"center\" justifyContent=\"center\" mt={12}>\r\n        <Box maxW={350}>\r\n          <Input\r\n            borderRightRadius={0}\r\n            placeholder=\"Search Resource name\"\r\n            onChange={(e) => {\r\n              setSearch(e.target.value);\r\n            }}\r\n          />\r\n        </Box>\r\n        <IconButton borderLeftRadius={0} icon={<SearchIcon />} />\r\n      </Flex>\r\n      <Flex alignItems=\"center\" justifyContent=\"space-around\" wrap=\"wrap\">\r\n        {resourceYear.length === 0 ? (\r\n          <Box mt={10}>\r\n            <Alert\r\n              status=\"warning\"\r\n              textAlign=\"center\"\r\n              borderRadius={5}\r\n              size=\"lg\"\r\n            >\r\n              <AlertIcon />\r\n              Ainda sem recursos aqui.\r\n            </Alert>\r\n          </Box>\r\n        ) : (\r\n          resourceYear\r\n            .filter((val) => {\r\n              if (search === \"\") return val;\r\n              else if (\r\n                val.name.toLowerCase().includes(search.toLocaleLowerCase())\r\n              ) {\r\n                return val;\r\n              }\r\n            })\r\n            .map((item, index) => {\r\n              return (\r\n                <Box key={index}>\r\n                  <ResourceCard\r\n                    author={item.author}\r\n                    resourceName={item.name}\r\n                    resourceURL={item.url}\r\n                  />\r\n                </Box>\r\n              );\r\n            })\r\n        )}\r\n      </Flex>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Subject;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\ResourceCard\\ResourceCard.js",["106"],"import React from \"react\";\r\nimport { Box, Button, Divider, Text } from \"@chakra-ui/react\";\r\nimport { DownloadIcon } from '@chakra-ui/icons'\r\n\r\nfunction ResourceCard({ resourceName, author, resourceURL }) {\r\n  return (\r\n    <Box\r\n      borderRadius={7}\r\n      mt={16}\r\n      w={300}\r\n      borderWidth={1}\r\n      boxShadow=\"2xl\"\r\n      padding={7}\r\n      mb={10}\r\n      mr={12}\r\n      ml={12}\r\n    >\r\n      <Text color=\"blue.500\" fontSize={28} fontWeight=\"bold\" textAlign=\"center\">\r\n        {author}\r\n      </Text>\r\n      <Text mt={7} fontSize={22} textAlign=\"center\">\r\n        {resourceName}\r\n      </Text>\r\n      <Box textAlign=\"center\" mt={7}>\r\n        <Button\r\n          as=\"a\"\r\n          download\r\n          target=\"blank\"\r\n          rel=\"noopener noreferrer\"\r\n          href={resourceURL}\r\n          colorScheme=\"blue\"\r\n          rightIcon={<DownloadIcon fontSize=\"18px\"/>}\r\n        >\r\n          Download\r\n        </Button>\r\n      </Box>\r\n    </Box>\r\n  );\r\n}\r\n\r\nexport default ResourceCard;\r\n","D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Mat11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Bg11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Fq11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\Subjects\\_11\\Pt11.js",[],"D:\\EstudaMais\\estuda_mais\\src\\components\\About\\About.js",[],{"ruleId":"107","replacedBy":"108"},{"ruleId":"109","replacedBy":"110"},{"ruleId":"111","severity":1,"message":"112","line":2,"column":29,"nodeType":"113","messageId":"114","endLine":2,"endColumn":35},{"ruleId":"107","replacedBy":"115"},{"ruleId":"109","replacedBy":"116"},{"ruleId":"111","severity":1,"message":"117","line":31,"column":3,"nodeType":"113","messageId":"114","endLine":31,"endColumn":11},{"ruleId":"111","severity":1,"message":"118","line":39,"column":10,"nodeType":"113","messageId":"114","endLine":39,"endColumn":30},{"ruleId":"111","severity":1,"message":"112","line":10,"column":3,"nodeType":"113","messageId":"114","endLine":10,"endColumn":9},{"ruleId":"119","severity":1,"message":"120","line":36,"column":6,"nodeType":"121","endLine":36,"endColumn":8,"suggestions":"122"},{"ruleId":"123","severity":1,"message":"124","line":72,"column":27,"nodeType":"125","messageId":"126","endLine":72,"endColumn":29},{"ruleId":"111","severity":1,"message":"127","line":2,"column":23,"nodeType":"113","messageId":"114","endLine":2,"endColumn":30},"no-native-reassign",["128"],"no-negated-in-lhs",["129"],"no-unused-vars","'Button' is defined but never used.","Identifier","unusedVar",["128"],["129"],"'LockIcon' is defined but never used.","'currentResourceCount' is assigned a value but never used.","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'db', 'subject', and 'year'. Either include them or remove the dependency array.","ArrayExpression",["130"],"array-callback-return","Array.prototype.filter() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","'Divider' is defined but never used.","no-global-assign","no-unsafe-negation",{"desc":"131","fi